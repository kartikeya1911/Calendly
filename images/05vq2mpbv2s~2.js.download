		}
	`}
	${e=>e.$signupPage&&ew.css`
		[data-testid="hero-with-form-title"] {
			font-weight: ${tr.FONT_WEIGHT.semiBold};
		}

		[data-testid="hero-with-form-badge"] {
			margin-top: 8px;
		}

		[data-testid="signup-form"] {
			padding: 0;
			box-shadow: unset;
			border: 0;
			background-color: transparent;
			${eM.MEDIA.largeTablet} {
				button {
					width: 100%;
				}
			}
		}

		[data-testid="hero-with-form-marketo-wrapper"],
		[data-testid="hero-with-form-content-wrapper"] {
			max-width: 480px;
		}
		[data-testid="social-signup"] {
			gap: 16px;
			button {
				min-height: 49px;
				img,
				svg {
					max-width: 34px;
				}
			}
		}
		[data-testid="trust-bar"] {
			[data-testid="trust-bar-items"] {
				gap: 24px 36px;
			}
		}
		[data-testid="list-items"] {
			[data-testid="list-item-icon"] {
				margin-top: 2px;
			}
			[data-testid="list-item-description"] {
				margin: 0;
				p {
					${te.TEXT_SIZE.bodyLg};
					font-weight: ${tr.FONT_WEIGHT.medium};
				}
			}
		}
		${eM.MEDIA.largeTablet} {
			&[data-testid="hero-with-form"] {
				padding-top: 40px;
			}
			[data-testid="signup-form-header"] {
				align-items: center;
				* {
					text-align: center;
				}
			}
			[data-testid="hero-with-form-badge"] {
				margin-top: 0;
			}
			[data-testid="hero-with-form-body"],
			[data-testid="hero-with-form-content-wrapper"] {
				max-width: 100%;
			}
			[data-testid="hero-with-form-content-wrapper"] {
				position: relative;
				& > * {
					position: relative;
				}
				&::before {
					content: '';
					position: absolute;
					width: 100vw;
					left: 50%;
					transform: translateX(-50%);
					top: -40px;
					bottom: -40px;
					background-color: ${e9.COLOR.main100N};
				}
			}
			[data-testid="hero-with-form-body"] {
				display: flex;
				flex-direction: column;
				ol {
					display: flex;
					flex-wrap: wrap;
					gap: 0 24px;
					li {
						width: calc((100% / 2) - 12px);
						p {
							font-size: 16px !important;
						}
					}
				}
			}

			[data-testid="trust-bar"] {
				max-width: 496px;
				align-self: center;
			}
		}
		${eM.MEDIA.tablet},
		${eM.MEDIA.mobile} {
			[data-testid="signup-form-description"] {
				padding-bottom: 24px;
			}
			&[data-testid="hero-with-form"] {
				padding-top: 40px;
			}
			[data-testid="hero-with-form-body"] {
				ol {
					margin-bottom: 0;
					padding-bottom: 16px;
					li {
						width: 100%;
						margin-bottom: 8px;
					}
				}
			}
		}
	`}
`,tl=(0,ew.default)(eR.Wrapper).withConfig({displayName:"HeroWithForm.atoms__BodyWrapper",componentId:"sc-51048ef1-1"})`
	> .single-input-field {
		margin: 0px;
	}
	> p {
		padding-bottom: 24px;
	}
	.button-container {
		justify-content: flex-start;
		margin-bottom: 24px;
		${eM.MEDIA.tablet} {
			flex-wrap: wrap;
			justify-content: flex-start;
		}
	}
	& > *:last-child {
		margin-bottom: 0;
		padding-bottom: 0;
	}
	${e=>e.$isSignup&&ew.css`
