	display: block;
	opacity: 0;
	visibility: hidden;
	pointer-events: none;
	border: none;
	border-radius: 24px;
	overflow: hidden;
	background-color: transparent;
	padding: 0;
	max-width: calc(100vw - 80px);
	width: fit-content;
	&[open] {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
	}
	&::backdrop {
		background-color: rgb(0,0,0,0.7);
		backdrop-filter: blur(4px);
		pointer-events: none;
	}
	${eM.MEDIA.largeTablet} {
		display: none;
	}
	${eM.MEDIA.tablet} {
		width: calc(100% - 48px);
	}
	[data-testid="signup-form"] {
		padding: 32px 40px;
	}
	[data-testid="signup-form-header"] p {
		${te.TEXT_SIZE.bodyMd};
		font-weight: ${tr.FONT_WEIGHT.medium};
	}
	[data-testid="signup-form-description"] {
		p {
			${te.TEXT_SIZE.bodySm};
			font-weight: ${tr.FONT_WEIGHT.medium};
		}
	}
	.modal-list-custom {
		li {
			display: flex;
			gap: 12px;
			align-items: center;
			.modal-checkmark-custom {
				position: relative;
				display: inline-flex;
				width: 32px;
				height: 32px;
				border-radius: 50%;
				border: 1.5px solid ${e9.COLOR.neutral600};
				align-items: center;
				justify-content: center;
				svg path {
					stroke: ${e9.COLOR.neutral500};
				}
				&::after {
					content: '';
					position: absolute;
					left: 50%;
					bottom: 0;
					width: 1.5px;
					height: 26px;
					transform: translate(-50%, 100%);
					background-color: ${e9.COLOR.neutral600};
				}
			}
		}
	}
	.modal-list-custom li:first-child .modal-checkmark-custom {
		border: 1.5px solid ${e9.COLOR.aqua500};
		&::after {
			background: linear-gradient(180deg, ${e9.COLOR.aqua500} 0%, ${e9.COLOR.neutral600} 100%);
		}
		svg path {
			stroke: white;
		}
	}
	.modal-list-custom li:last-child .modal-checkmark-custom::after {
		content: unset;
	}
	.signup-form-description {
		background-image: url('/media/backgrounds/contact-bg.svg');
		background-repeat: no-repeat;
		background-size: cover;
	}
