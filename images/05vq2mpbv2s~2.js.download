						height: 816px !important;
						transform: translateX(-50%);
						pointer-events: none;
						filter: blur(70px);

						&:has(+[data-testid="testimonial"]) {
							.notetaker-gradient-circle {
								opacity: 0.3;
							}

							height: 708px !important;

							${eM.MEDIA.largeTablet} {
								height: 474px !important;
							}

							${eM.MEDIA.tablet} {
								height: 474px !important;
							}

							${eM.MEDIA.mobile} {
								height: 600px !important;
							}
						}

						${eM.MEDIA.desktop} {
							top: ${e=>e.$_css2};
						}

						${eM.MEDIA.largeTablet} {
							top: ${e=>e.$_css3};
							height: 530px !important;
						}

						${eM.MEDIA.tablet} {
							top: ${e=>e.$_css4};
							height: 530px !important;
						}

						${eM.MEDIA.mobile} {
							top: ${e=>e.$_css5};
							width: 150% !important;
							height: 254px !important;
						}

						.notetaker-gradient-wrapper {
							position: relative;
							top: 0;
							left: 0;
							width: 100%;
							height: 100%;
							overflow: hidden;
						}

						.notetaker-rotation-animation {
							position: absolute;
							left: 0;
							aspect-ratio: 1 / 1;
							width: 100%;
							height: 100%;
							animation: ${rW} 12s linear infinite;
						}

						.notetaker-gradient-circle {
							position: absolute;
							aspect-ratio: 1 / 1;
							height: 125%;
							pointer-events: none;
							border-radius: 50%;
							opacity: 0.7;
						}

						.notetaker-gradient-circle-1 {
							background: ${e9.COLOR.purple500};
							bottom: -44%;
							left: 45%;
						}
						.notetaker-gradient-circle-2 {
							background: ${e9.COLOR.aqua300};
							top: -44%;
							left: 45%;
						}
						.notetaker-gradient-circle-3 {
							background: ${e9.COLOR.purple500};
							top: -44%;
							right: 45%;
						}
						.notetaker-gradient-circle-4 {
							background: ${e9.COLOR.aqua300};
							bottom: -44%;
							right: 45%;
						}
