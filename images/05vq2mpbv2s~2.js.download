	> a {
		display: inline;
		font-size: inherit;
		text-underline-offset: 2px;
	}

	a:only-of-type {
		margin: 0px;
	}

	// overrides our focus style with new one for inline-links that can break in multiple lines
	@media (any-hover: hover) {
		a:focus,
		a:focus-visible {
			outline: 2px ${e=>e.$whiteText?a.COLOR.baseWhite:a.COLOR.main600P} solid;
