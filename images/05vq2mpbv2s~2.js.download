	position: relative;

	& > div {
		position: absolute;
		z-index: 0;
		top: 0;
		left: 0;
		opacity: 0;
		transform: translateX(40px);
		transition: none;
		pointer-events: none;
		visibility: hidden;
	}

	& > div:nth-child(${e=>e.$activeTab+1}) {
		position: relative;
		z-index: 1;
		opacity: 1;
		transform: translateX(0);
		transition: opacity 0.35s ease-in-out, transform 0.35s ease-in-out;
		pointer-events: auto;
		visibility: visible;
	}

	${eM.MEDIA.largeTablet} {
		display: flex;
		align-items: stretch;
		gap: 24px;
		// negative margin and positive padding so the tough
		// box-shadow effect stays visible and is not cut off
		margin: -36px -24px;
    	padding: 36px 24px;
		overflow-x: auto;
    	scroll-snap-type: x mandatory;
		-ms-overflow-style: none;
		scrollbar-width: none;
		overflow: -moz-scrollbars-none;

		&::-webkit-scrollbar {
			width: 0 !important;
		}

		& > div {
			scroll-snap-align: center;
			width: 100%;
			flex: 1 0 100%;
			position: relative;
			opacity: 1;
			transform: none;
			transition: none;
			pointer-events: auto;
			visibility: visible;
		}
	}
`,nl=ew.default.button.attrs(e=>({$borderRadius:"0px",$focusOffsetLeft:"0px",$focusOffsetRight:"0px",$focusOffsetTop:"0px",$focusOffsetBottom:"0px",...e})).withConfig({displayName:"TestemonialStory.atoms__Tab",componentId:"sc-6a258f6-1"})`
	--progress-bar: 0%;
	display: flex;
	position: relative;
	width: 100%;
	padding: 24px 8px;
	justify-content: center;
	transition: border-color 0.2s ease-in-out;
	border-bottom: 2px solid transparent;

	> div {
		.next-image-wrapper:nth-child(1) {
			position: relative;
			background-color: ${e9.COLOR.neutral500};
			pointer-events: none;
		}

		.next-image-wrapper:nth-child(2) {
			position: absolute;
			top: 0;
			right: 0;
			bottom: 0;
			left: 0;
			transition: opacity 0.2s ease-in-out;
		}
	}

	${e=>!e.$activeTab&&ew.css`
		> div {
			.next-image-wrapper:nth-child(2) {
				opacity: 0;
			}
		}
	`}

	${tW.keyboardFocus}

	&:hover {
		cursor: pointer;
		${e=>!e.$activeTab&&ew.css`
			> div {
				.next-image-wrapper:nth-child(2) {
					opacity: 1;
				}
			}
		`}
	}

	&::after {
		content: '';
		position: absolute;
		bottom: -2px;
		left: 0;
		right: 0;
		height: 2px;
		background: transparent;
		transition: background-color 0.2s ease-in-out;
	}

	${e=>e.$activeTab&&ew.css`
		border-color: ${e9.COLOR.neutral400};

		&::after {
			width: var(--progress-bar);
			background: linear-gradient(90deg, ${e9.COLOR[e.$progressBarColor]} var(--progress-bar), ${e9.COLOR.neutral400} calc(var(--progress-bar) + 100%));

			@media (prefers-reduced-motion) {
				width: 100%;
				background: ${e9.COLOR[e.$progressBarColor]};
			}
		}
	`}
