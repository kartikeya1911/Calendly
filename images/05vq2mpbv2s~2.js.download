	position: relative;
	list-style-type: disc;
	text-align: left;
	margin: 0 0 24px 1.5em;

	& > li:last-child {
		margin-bottom: 0;
	}

	li {
		break-inside: avoid-column;
		margin-bottom: 12px;

		&::marker {
			font-size: 0.8em;
		}

		> p {
			padding-bottom: 0;
			margin-bottom: 12px;
		}

		& > *:last-child {
