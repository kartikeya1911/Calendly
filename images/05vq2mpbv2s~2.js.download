    height: auto;
    width: auto;
    position: relative;
    overflow: hidden;

    * {
        position: relative;
        z-index: 1;
    }

    > svg {
        position: absolute;
        z-index: 0;
        width: 100%;
        height: auto;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);

        .animated-shape-01 {
            fill: ${e=>e.$firstEleColor?o.COLOR[e.$firstEleColor]:o.COLOR.primary500};
        }

        .animated-shape-02 {
            fill: ${e=>e.$secondEleColor?o.COLOR[e.$secondEleColor]:o.COLOR.pink500};
            mix-blend-mode: multiply;
        }
    }
	[data-testid="image"] svg {
		width: 100%;
