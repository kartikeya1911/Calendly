					${te.TEXT_SIZE.h2};
				}
			}
		}
	`}
`,ts=ew.createGlobalStyle`
	section#\\[Signup\\]-Hero {
		display: flex;
		flex: 1;
		border-bottom: 1px solid ${e9.COLOR.neutral300};
		height: 100%;
		background: ${`linear-gradient(to right, ${e9.COLOR.baseWhite} 50%, ${e9.COLOR.main100N} 50%)`};
		${eM.MEDIA.largeTablet} {
			background: none;
		}
	}
`,td=ew.createGlobalStyle`
	section#\\[Form\\]ContactGenericV2Hero {
		display: flex;
		flex: 1;
		border-bottom: 1px solid ${e9.COLOR.neutral300};
		height: 100%;
		background-image: url('/media/backgrounds/contact-bg-v2.svg');
		background-position: center;
		background-repeat: no-repeat;
		background-size: cover;
		${eM.MEDIA.largeTablet} {
			background: none;
		}

		[data-testid="hero-with-form-marketo-wrapper"],
		[data-testid="hero-with-form-content-wrapper"] {
			max-width: 480px;
			${eM.MEDIA.largeTablet} {
				max-width: unset;
			}
		}
		form#mktoForm_2588 {
			padding: 0;
			background: transparent;
			h3 {
				font-weight: bold;
			}
		}
		form#mktoForm_2588,
		.marketo-form-loader {
			border: none;
			box-shadow: none;
			background: transparent;
		}
		.marketo-form-loader.contact-page-experiment {
			position: absolute; // layout shift fix
			left: 50%;
			.logo-loader {
				width: 100%;
			}
		}
	}

	section#\\[Form\\]ContactGeneric-TrustBar {
		display: none;
	}

	[data-testid="list-item-description"] p {
		font-weight: ${tr.FONT_WEIGHT.medium};
	}

	[data-testid="trust-bar-items"] {
		gap: 24px;
	}

	.chat-icon {
		width: 48px;
		height: auto;
		min-width: 48px;
		min-height: 48px;
