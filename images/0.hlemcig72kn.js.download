					padding-bottom: 0;
					margin-bottom: 32px;
				}
				& > div:has(.dotlottie-container),
				& > div:has([data-testid="switchback"]),
				& > div:has([data-testid="conversion-panel"]),
				& > div:has([data-testid="two-column-hero"]),
